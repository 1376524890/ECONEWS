APP_NAME=EconoNews Intelligence Hub
API_V1_PREFIX=/api/v1
SCHEDULER_ENABLED=true
CRAWLER_INTERVAL_SECONDS=300
DEFAULT_BENCHMARK=000300.SH
# NLP 提供者类型: heuristic (启发式规则) | bert (预训练模型)
MODEL_PROVIDER=heuristic
# BERT 模型配置 (仅在 MODEL_PROVIDER=bert 时生效)
BERT_MODEL_NAME=Chinese-FinBERT
# 启用 FP16 推理以降低显存占用 (true/false)
BERT_FP16=false
LLM_ENDPOINT=
TUSHARE_TOKEN=

